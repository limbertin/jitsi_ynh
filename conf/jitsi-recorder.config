# /etc/jitsi-recorder/config
#
# Sourced by:
#   /etc/systemd/system/jitsi-recorder@.service
#   /etc/cron.daily/jitsi-recorder-retention
#   /opt/jitsi-recorder/recorder-pipeline.sh (when launched via the unit)
#
# Phase 5 of this fork (config_panel.toml) overwrites this file when the
# admin changes settings in the YunoHost web UI. Until then, hand-edit and
# `systemctl daemon-reload` (no service restart needed; values are read on
# each instance start).

# audio_only | smart_video | disabled
RECORDING_MODE=audio_only

# Where finished recordings land. Created by scripts/install with 0755 root:root.
RECORDINGS_DIR=/home/yunohost.app/jitsi/recordings

# Daily cron deletes .webm files older than this many days. 0 disables retention.
RETENTION_DAYS=365

# If MemAvailable at unit-start time is below this many KB, the wrapper forces
# audio_only regardless of RECORDING_MODE.
LOW_MEM_KB=256000
